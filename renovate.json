{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "labels": ["renovate"],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchManagers": ["helm-values"],
      "matchPackageNames": ["lscr.io/linuxserver/homeassistant"],
      "automerge": false
    }
  ]
}
