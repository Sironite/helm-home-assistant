{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "addons": {
            "description": "Optional addons that run as sidecar containers alongside Home Assistant.",
            "type": "object",
            "properties": {
                "codeserver": {
                    "description": "VS Code in the browser (code-server), sharing the `/config` volume with Home Assistant. Gives you a full editor for `configuration.yaml`, automations, and custom components without needing shell access to the node.",
                    "type": "object",
                    "properties": {
                        "authentikOutpost": {
                            "description": "Authentik proxy outpost for code-server. An outpost is a lightweight reverse proxy deployed next to your app that enforces Authentik authentication before forwarding traffic. It replaces the need for a built-in login screen — any user who hits code-server must first authenticate via your Authentik SSO. The outpost calls back to the Authentik server to validate sessions. Requires [Authentik](https://goauthentik.io) installed in the cluster and a Proxy Provider + Outpost configured for code-server.",
                            "type": "object",
                            "properties": {
                                "authentikHost": {
                                    "description": "Cluster-internal URL of the Authentik server (used by the outpost to validate sessions).",
                                    "type": "string"
                                },
                                "authentikHostBrowser": {
                                    "description": "Public-facing Authentik URL (used for browser redirects to the login page).",
                                    "type": "string"
                                },
                                "enabled": {
                                    "description": "Enable the Authentik proxy outpost Deployment and Service.",
                                    "type": "boolean"
                                },
                                "existingSecret": {
                                    "description": "Name of an existing Kubernetes Secret containing the outpost token under key `token`. Mutually exclusive with `externalSecret`. Create this secret manually or via another tool.",
                                    "type": "string"
                                },
                                "externalSecret": {
                                    "description": "Fetch the outpost token from an external secret store via ESO instead of an existing secret.",
                                    "type": "object",
                                    "properties": {
                                        "enabled": {
                                            "description": "Enable ExternalSecret rendering for the outpost token.",
                                            "type": "boolean"
                                        },
                                        "remoteKey": {
                                            "description": "Key in the secret store that holds the outpost token (must have a `token` property).",
                                            "type": "string"
                                        },
                                        "secretStoreRef": {
                                            "description": "ClusterSecretStore name.",
                                            "type": "string"
                                        }
                                    }
                                },
                                "image": {
                                    "description": "Authentik proxy image.",
                                    "type": "object",
                                    "properties": {
                                        "repository": {
                                            "type": "string"
                                        },
                                        "tag": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "resources": {
                                    "description": "Resource requests and limits for the outpost proxy container.",
                                    "type": "object",
                                    "properties": {
                                        "limits": {
                                            "type": "object",
                                            "properties": {
                                                "cpu": {
                                                    "type": "string"
                                                },
                                                "memory": {
                                                    "type": "string"
                                                }
                                            }
                                        },
                                        "requests": {
                                            "type": "object",
                                            "properties": {
                                                "cpu": {
                                                    "type": "string"
                                                },
                                                "memory": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        },
                        "enabled": {
                            "description": "Enable the code-server sidecar.",
                            "type": "boolean"
                        },
                        "env": {
                            "description": "Environment variables for code-server. Runs as the same PUID/PGID as Home Assistant so it has full read/write access to `/config`.",
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "value": {
                                        "type": "string"
                                    }
                                }
                            }
                        },
                        "image": {
                            "description": "code-server container image (LSIO build).",
                            "type": "object",
                            "properties": {
                                "repository": {
                                    "type": "string"
                                },
                                "tag": {
                                    "description": "Image tag. Defaults to `Chart.appVersion` when empty.",
                                    "type": "string"
                                }
                            }
                        },
                        "ingress": {
                            "description": "Standard Kubernetes Ingress for code-server. Use when a Gateway API HTTPRoute is not available.",
                            "type": "object",
                            "properties": {
                                "annotations": {
                                    "description": "Annotations merged onto the Ingress resource.",
                                    "type": "object"
                                },
                                "className": {
                                    "description": "IngressClass name (e.g. `nginx`, `traefik`).",
                                    "type": "string"
                                },
                                "enabled": {
                                    "description": "Enable Ingress rendering for code-server.",
                                    "type": "boolean"
                                },
                                "hostname": {
                                    "description": "Hostname for the code-server Ingress rule.",
                                    "type": "string"
                                },
                                "tls": {
                                    "description": "TLS configuration.",
                                    "type": "array"
                                }
                            }
                        },
                        "resources": {
                            "description": "Resource requests and limits for the code-server container.",
                            "type": "object",
                            "properties": {
                                "limits": {
                                    "type": "object",
                                    "properties": {
                                        "cpu": {
                                            "type": "string"
                                        },
                                        "memory": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "requests": {
                                    "type": "object",
                                    "properties": {
                                        "cpu": {
                                            "type": "string"
                                        },
                                        "memory": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        },
                        "service": {
                            "description": "Service for code-server. Use `ClusterIP` and protect with an Authentik outpost.",
                            "type": "object",
                            "properties": {
                                "port": {
                                    "type": "integer"
                                },
                                "type": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        },
        "dnsPolicy": {
            "description": "DNS policy for the pod. Should be `ClusterFirstWithHostNet` when `hostNetwork` is enabled.",
            "type": "string"
        },
        "env": {
            "description": "Environment variables injected into the Home Assistant container. The LSIO image requires `PUID`/`PGID` — the HA process runs as UID 1000, not root.",
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "value": {
                        "type": "string"
                    }
                }
            }
        },
        "externalSecrets": {
            "description": "External Secrets Operator integration for pulling secrets from an external secret store. Requires [ESO](https://external-secrets.io) installed in the cluster. Each item creates an `ExternalSecret` resource that syncs a secret from the store into a Kubernetes `Secret`, which is then mounted into the Home Assistant (and optionally code-server) containers.",
            "type": "object",
            "properties": {
                "enabled": {
                    "description": "Enable ExternalSecret rendering.",
                    "type": "boolean"
                },
                "items": {
                    "description": "List of secrets to sync.",
                    "type": "array"
                }
            }
        },
        "fullnameOverride": {
            "description": "Override the full resource name prefix.",
            "type": "string"
        },
        "hostNetwork": {
            "description": "Enable host network access. Required for mDNS device discovery (Hue, Chromecast, SSDP, Zigbee, etc.). When enabled, the namespace PSS label is automatically set to `privileged`.",
            "type": "boolean"
        },
        "httproutes": {
            "description": "Gateway API `HTTPRoute` resources. Requires [Gateway API CRDs](https://gateway-api.sigs.k8s.io).",
            "type": "array"
        },
        "image": {
            "description": "Home Assistant container image.",
            "type": "object",
            "properties": {
                "pullPolicy": {
                    "description": "Image pull policy.",
                    "type": "string"
                },
                "repository": {
                    "description": "Image repository.",
                    "type": "string"
                },
                "tag": {
                    "description": "Image tag. Defaults to `Chart.appVersion` when empty.",
                    "type": "string"
                }
            }
        },
        "ingress": {
            "description": "Standard Kubernetes Ingress resource. Use when a Gateway API HTTPRoute is not available.",
            "type": "object",
            "properties": {
                "annotations": {
                    "description": "Annotations merged onto the Ingress resource.",
                    "type": "object"
                },
                "className": {
                    "description": "IngressClass name (e.g. `nginx`, `traefik`).",
                    "type": "string"
                },
                "enabled": {
                    "description": "Enable Ingress rendering.",
                    "type": "boolean"
                },
                "hostname": {
                    "description": "Hostname for the Ingress rule.",
                    "type": "string"
                },
                "tls": {
                    "description": "TLS configuration.",
                    "type": "array"
                }
            }
        },
        "nameOverride": {
            "description": "Override the chart name used in resource names and labels.",
            "type": "string"
        },
        "namespaceLabels": {
            "description": "Extra labels merged onto the Namespace created by this chart. Useful for gateway selectors or additional PSS annotations. The Pod Security Standards labels are managed automatically — no need to add them here.",
            "type": "object"
        },
        "networkPolicy": {
            "description": "NetworkPolicy configuration.",
            "type": "object",
            "properties": {
                "cilium": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "description": "Enable CiliumNetworkPolicy rendering. Requires [Cilium CNI](https://cilium.io).",
                            "type": "boolean"
                        }
                    }
                },
                "extraEgress": {
                    "description": "Extra egress rules appended to the NetworkPolicy (both Cilium and Kubernetes).",
                    "type": "array"
                },
                "extraIngress": {
                    "description": "Extra ingress rules appended to the NetworkPolicy (both Cilium and Kubernetes).",
                    "type": "array"
                },
                "kubernetes": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "description": "Enable standard Kubernetes NetworkPolicy rendering. Works with any CNI that supports NetworkPolicy.",
                            "type": "boolean"
                        }
                    }
                },
                "mqttNamespace": {
                    "description": "Namespace of the MQTT broker (e.g. EMQX). When set, adds an egress rule on port 1883.",
                    "type": "string"
                },
                "postgresNamespace": {
                    "description": "Namespace of the PostgreSQL cluster. When set, adds an egress rule on port 5432.",
                    "type": "string"
                },
                "prometheusNamespace": {
                    "description": "Namespace where Prometheus runs. When set, adds an ingress rule allowing Prometheus scraping on port 8123.",
                    "type": "string"
                }
            }
        },
        "persistence": {
            "description": "Persistent storage for the Home Assistant `/config` directory.",
            "type": "object",
            "properties": {
                "enabled": {
                    "description": "Enable the PersistentVolumeClaim.",
                    "type": "boolean"
                },
                "size": {
                    "description": "Storage size.",
                    "type": "string"
                },
                "storageClassName": {
                    "description": "StorageClass name. Defaults to the cluster default when empty.",
                    "type": "string"
                }
            }
        },
        "resources": {
            "description": "Resource requests and limits for the Home Assistant container.",
            "type": "object",
            "properties": {
                "limits": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "type": "string"
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                },
                "requests": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "type": "string"
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "service": {
            "description": "Kubernetes Service configuration.",
            "type": "object",
            "properties": {
                "annotations": {
                    "description": "Annotations merged onto the Service resource.",
                    "type": "object"
                },
                "port": {
                    "description": "Port to expose.",
                    "type": "integer"
                },
                "type": {
                    "description": "Service type. Use `LoadBalancer` to expose HA directly on the LAN.",
                    "type": "string"
                }
            }
        },
        "sshKnownHosts": {
            "description": "SSH `known_hosts` entries pre-loaded into code-server for authenticated git operations. Without this, the first `git push/pull` to a new host blocks on an interactive host-key prompt, which is not possible inside a browser-based editor. Add one line per host.",
            "type": "object",
            "properties": {
                "content": {
                    "description": "Raw known_hosts content (one entry per line). Get entries with: `ssh-keyscan github.com`",
                    "type": "string"
                },
                "enabled": {
                    "description": "Enable the known_hosts ConfigMap and mount it into code-server.",
                    "type": "boolean"
                }
            }
        }
    }
}
